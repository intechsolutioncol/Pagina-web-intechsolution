# ─── Supabase ───────────────────────────────────────────────
# Obtén estos valores en: supabase.com → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...tu_anon_key_aqui

# Solo para API routes (server-side). NUNCA lo expongas al cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...tu_service_role_key_aqui

# ─── Admin Panel ─────────────────────────────────────────────
# Contraseña para acceder a /admin (cámbiala por una segura)
ADMIN_PASSWORD=intechsecure2025
